[user]
	name = servitola
	email = servitola@gmail.com

[branch]
	sort = -committerdate

[core]
	editor = code -w
	excludesfile = ~/projects/dotfiles/git/global_ignore

[credential]
  helper = osxkeychain

[diff]
    renames = copies
    algorithm = histogram

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[pager]
    diff = "diff-so-fancy | less --tabs=4 -RFX"
    show = "diff-so-fancy | less --tabs=4 -RFX"

[init]
	defaultBranch = main

[gui]
	gcwarning = false

[pull]
  	rebase = true

[merge]
	conflictstyle = zdiff3

[push]
  	followTags = true
	autoSetupRemote = true

[fetch]
	prune = true

[commit]
	verbose = true

[rebase]
	autoStash = true
	updateRefs = true

[rerere]
	enabled = true

[help]
	autocorrect = prompt

[include]
	path = "~/projects/dotfiles/git/aliases.gitconfig"
	path = "~/projects/dotfiles/git/colors.gitconfig"
	; work-specific sections (private overlay; silently skipped when absent)
	path = "~/projects/dotfiles_private/git/work.gitconfig"

[http "https://github.com"]
	proxy =
[http]
	proxy =
[https]
	proxy =
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://dev.azure.com"]
	useHttpPath = true
