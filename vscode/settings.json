{
    "editor.fontFamily": "JetBrainsMono Nerd Font",
    "editor.fontSize": 17,
    "terminal.integrated.fontSize": 17,
    "editor.lineHeight": 1.5,
    "editor.renderWhitespace": "boundary",
    "editor.rulers": [
        120
    ],
    "editor.minimap.enabled": false,
    "editor.formatOnSave": true,
    "editor.suggestSelection": "first",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "workbench.colorTheme": "Gruvbox Dark Hard",
    "workbench.startupEditor": "none",
    "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
    "csharp.preview.improvedLaunchExperience": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": false
    },
    "dotnet-test-explorer.testProjectPath": "**/*Tests.@(csproj|vbproj|fsproj)",
    "dotnet-test-explorer.autoWatch": true,
    "dotnet-test-explorer.testArguments": "/p:CollectCoverage=true",
    "dotnet-test-explorer.showCodeLens": true,
    "dotnet-test-explorer.codeLensFailed": "❌",
    "dotnet-test-explorer.codeLensPassed": "✅",
    "dotnet-test-explorer.codeLensSkipped": "⚠️",
    "window.zoomLevel": 2,
    "cline.chromeExecutablePath": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
    "roo-cline.allowedCommands": [
        "npm test",
        "npm install",
        "tsc",
        "git log",
        "git diff",
        "git show"
    ],
    "security.workspace.trust.untrustedFiles": "open",
    "terminal.external.osxExec": "Warp.app",
    "git.autofetch": true,
    "editor.wordBasedSuggestions": "off",
    "git.openRepositoryInParentFolders": "always",
    "chat.agent.maxRequests": 60,
    "go.gopath": "/Users/servitola/go",
    "go.goroot": "/opt/homebrew/opt/go/libexec",
    "go.toolsManagement.autoUpdate": true,
    "security.promptForLocalFileProtocolHandling": false,
    "telemetry.telemetryLevel": "off",
    "dotnetAcquisitionExtension.enableTelemetry": false,
    "claudeCode.preferredLocation": "panel",
    "claudeCode.initialPermissionMode": "plan"
}
