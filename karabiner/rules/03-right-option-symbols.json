{
    "description": "Right Option + C \u2192 \u00a9 (abc_copy)",
    "manipulators": [
        {
            "from": {
                "key_code": "c",
                "modifiers": {
                    "mandatory": [
                        "right_option"
                    ]
                }
            },
            "to": [
                {
                    "shell_command": "printf $(printf '00A9' | xxd -r -p) | pbcopy"
                },
                {
                    "hold_down_milliseconds": 30,
                    "key_code": "vk_none"
                },
                {
                    "key_code": "v",
                    "modifiers": [
                        "left_command"
                    ]
                }
            ],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "e",
