#!/usr/bin/env python3
"""Send a JSON banner spec to NotifyDaemon over its Unix socket.

Reads JSON from argv[1] (preferred for scripting) or stdin. Closes
the socket cleanly so Hammerspoon (or any caller) doesn't block.

Usage:
    notify-send '{"action":"show","title":"X","body":"Y","tint":"green"}'
    echo '{"action":"clear"}' | notify-send
"""
import socket
import sys

SOCK_PATH = "/Users/servitola/.notifyd.sock"


def main() -> int:
    payload = sys.argv[1] if len(sys.argv) > 1 else sys.stdin.read()
    if not payload.strip():
        return 0
    if not payload.endswith("\n"):
        payload += "\n"
    try:
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        s.settimeout(0.5)
        s.connect(SOCK_PATH)
        s.sendall(payload.encode("utf-8"))
        s.close()
    except OSError as e:
        print(f"notify-send: {e}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
