#!/bin/bash
# make-avd — create & launch optimally tuned Android AVDs on Apple Silicon.
#
# Tuned for M1 Max / 32 GB, macOS 26+. Why each default (evidence-based):
#   gpu=host      'auto' resolves to lavapipe/swiftshader (CPU rasterizer) on this
#                 host -> guest loadavg 20-40, SystemUI/Launcher ANR storms.
#                 'host' renders via gfxstream/ANGLE on the Metal GPU.
#                 Guest ANGLE is unstable for API > 35 (emulator's own warning),
#                 so never use guest mode either.
#   ram=4096      Play Store images (API 35/36) use ~1.7 GB right after boot;
#                 2048 keeps the guest in permanent memory pressure (kswapd/LMK).
#   heap=512      default 228 caps per-app Dalvik heap; WebView-heavy apps GC-storm.
#   cores=6       6 of 8 P-cores for vCPUs; leaves 2P+2E for host, QEMU render
#                 and I/O threads. More vCPUs would fight QEMU's own threads.
#   disk=16G      6G fills up with GMS/Play updates; qcow2 grows lazily, so 16G
#                 costs only what is actually written.
#   cold boot     quickboot snapshot restore skews the guest clock (ping rtt in
#                 quadrillions of ms, false ANR watchdogs, dead TCP feeds).
#   -no-audio     host CoreAudio goes through eqMac; emulator audio adds load
#                 and stutter, and is rarely needed.
set -euo pipefail

SDK="${ANDROID_SDK_ROOT:-$HOME/Library/Android/sdk}"
EMU="$SDK/emulator/emulator"
ADB="$SDK/platform-tools/adb"
AVDMANAGER="$SDK/cmdline-tools/latest/bin/avdmanager"
SDKMANAGER="$SDK/cmdline-tools/latest/bin/sdkmanager"
AVD_HOME="${ANDROID_AVD_HOME:-$HOME/.android/avd}"

RAM=4096 CORES=6 HEAP=512 DISK=16G GPU=host
SNAPSHOT=no LAUNCH=yes RECREATE=no WAIT=yes

usage() {
  cat <<'EOF'
make-avd — perfectly tuned Android AVDs for Apple Silicon (M1 Max / 32 GB)

Usage:
  make-avd <api-level> [options]     create (idempotent) and launch, e.g. make-avd 35
  make-avd launch <name> [options]   launch an existing AVD with the right flags
  make-avd doctor                    diagnose: HVF, stuck qemu, host load, versions
  make-avd list                      list AVDs with their key settings
  make-avd delete <name>             delete an AVD

Options:
  --name NAME    AVD name (default: api<level>, e.g. api35)
  --ram MB       guest RAM       (default 4096)
  --cores N      vCPU count      (default 6)
  --heap MB      vm.heapSize     (default 512)
  --disk SIZE    /data partition (default 16G)
  --gpu MODE     host|swiftshader_indirect (default host; never auto/guest)
  --snapshot     enable quickboot snapshots (default: cold boot — reliable clocks)
  --recreate     delete and re-create the AVD from scratch
  --no-launch    only create/fix the AVD, don't start it
  --no-wait      don't wait for boot_completed / skip health check
EOF
  exit "${1:-0}"
}

log()  { printf '\033[1;34m[make-avd]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[make-avd]\033[0m %s\n' "$*"; }
die()  { printf '\033[1;31m[make-avd]\033[0m %s\n' "$*" >&2; exit 1; }

set_ini() { # set_ini <file> <key> <value>
  local f=$1 k=$2 v=$3
  if grep -q "^${k}=" "$f" 2>/dev/null; then
    sed -i '' "s|^${k}=.*|${k}=${v}|" "$f"
  else
    echo "${k}=${v}" >>"$f"
  fi
}

require_tools() {
  [ -x "$EMU" ] || die "emulator not found at $EMU"
  [ -x "$AVDMANAGER" ] || die "avdmanager not found at $AVDMANAGER"
}

pick_image() { # pick_image <api> -> echoes package path, installs if missing
  local api=$1 pkg
  for tag in google_apis_playstore google_apis; do
    pkg="system-images;android-${api};${tag};arm64-v8a"
    if [ -d "$SDK/system-images/android-${api}/${tag}/arm64-v8a" ]; then
      echo "$pkg"; return 0
    fi
  done
  pkg="system-images;android-${api};google_apis_playstore;arm64-v8a"
  warn "image for API $api not installed — installing $pkg (this downloads ~1.5 GB)" >&2
  yes | "$SDKMANAGER" "$pkg" >/dev/null || die "failed to install $pkg"
  echo "$pkg"
}

pick_device() { # newest pixel profile known to this avdmanager
  local d
  for d in pixel_9a pixel_9 pixel_8a pixel_8; do
    if "$AVDMANAGER" list device -c 2>/dev/null | grep -qx "$d"; then echo "$d"; return; fi
  done
  echo pixel
}

tune_config() { # tune_config <config.ini>
  local f=$1
  set_ini "$f" hw.ramSize "$RAM"
  set_ini "$f" vm.heapSize "$HEAP"
  set_ini "$f" hw.cpu.ncore "$CORES"
  set_ini "$f" hw.gpu.enabled yes
  set_ini "$f" hw.gpu.mode "$GPU"
  set_ini "$f" disk.dataPartition.size "$DISK"
  set_ini "$f" hw.keyboard yes
  set_ini "$f" runtime.network.latency none
  set_ini "$f" runtime.network.speed full
  if [ "$SNAPSHOT" = yes ]; then
    set_ini "$f" fastboot.forceColdBoot no
    set_ini "$f" fastboot.forceFastBoot yes
  else
    set_ini "$f" fastboot.forceColdBoot yes
    set_ini "$f" fastboot.forceFastBoot no
  fi
}

serial_of() { # serial_of <avd-name> -> adb serial (handles USB phones + other emulators)
  local s n
  for s in $("$ADB" devices 2>/dev/null | awk '/^emulator-/{print $1}'); do
    n=$("$ADB" -s "$s" emu avd name 2>/dev/null | head -1 | tr -d '\r')
    [ "$n" = "$1" ] && { echo "$s"; return 0; }
  done
  return 1
}

launch_avd() { # launch_avd <name>
  local name=$1
  local logf="$AVD_HOME/${name}.avd/launch.log"
  local flags=(-avd "$name" -gpu "$GPU" -no-audio -no-boot-anim
               -netdelay none -netspeed full -restart-when-stalled)
  [ "$SNAPSHOT" = yes ] || flags+=(-no-snapshot)
  log "launching: emulator ${flags[*]}"
  # launchctl: emulator must not inherit background QoS from a script/agent/cron
  # shell (darwinbg pins all vCPUs to the 2 E-cores -> guest loadavg 30+, ANR);
  # launchd spawns it with default QoS (PRI ~46) in the GUI session
  local label="make-avd-$name"
  launchctl remove "$label" 2>/dev/null || true
  launchctl submit -l "$label" -o "$logf" -e "$logf" -- "$EMU" "${flags[@]}" \
    || die "launchctl submit failed"
  local pid=""
  for _ in $(seq 1 15); do
    pid=$(pgrep -f "qemu-system.*-avd $name" | head -1) && [ -n "$pid" ] && break
    sleep 1
  done
  [ -n "$pid" ] || { tail -5 "$logf" 2>/dev/null; die "emulator did not start — see $logf"; }
  local pri
  pri=$(ps -o pri= -p "$pid" | tr -d ' ')
  log "emulator pid $pid (priority $pri), log: $logf"
  [ "${pri:-0}" -ge 20 ] || warn "emulator is background-clamped (PRI $pri) — expect starvation"
  [ "$WAIT" = yes ] || return 0

  log "waiting for boot_completed (max 300s)..."
  local start=$SECONDS
  "$ADB" start-server >/dev/null 2>&1 || true
  local booted=no serial=""
  while [ $((SECONDS - start)) -lt 300 ]; do
    kill -0 "$pid" 2>/dev/null || { tail -5 "$logf"; die "emulator process died — see $logf"; }
    [ -n "$serial" ] || serial=$(serial_of "$name" || true)
    if [ -n "$serial" ] &&
       [ "$("$ADB" -s "$serial" shell getprop sys.boot_completed 2>/dev/null | tr -d '\r')" = 1 ]; then
      booted=yes; break
    fi
    sleep 2
  done
  [ "$booted" = yes ] || die "boot timeout after $((SECONDS - start))s — see $logf"
  log "boot completed in $((SECONDS - start))s (serial $serial)"

  # Full on-screen keyboard, like a real phone. hw.keyboard=yes gives host-keyboard
  # passthrough (convenient for typing) but also registers a virtual ALPHAKEY device,
  # which makes Android HIDE the soft IME — so text fields focus with no visible
  # keyboard (esp. inside WebViews). We almost always want the real on-screen keyboard,
  # so force it. Secure setting: persists across reboots; applied here at boot (before
  # any input connection) so the IME honours it — setting it mid-session does NOT apply
  # and needs a reboot.
  "$ADB" -s "$serial" shell settings put secure show_ime_with_hard_keyboard 1 >/dev/null 2>&1 \
    && log "on-screen keyboard forced (show_ime_with_hard_keyboard=1)" \
    || warn "could not force on-screen keyboard (show_ime_with_hard_keyboard)"

  sleep 5
  local load vk
  load=$("$ADB" -s "$serial" shell cat /proc/loadavg 2>/dev/null | awk '{print $1, $2, $3}')
  vk=$(grep -m1 -oE 'vulkan_mode_selected:[a-z]+ gles_mode_selected:[a-z]+' "$logf" 2>/dev/null || true)
  log "guest loadavg: ${load:-n/a} (target: settles below $CORES)"
  [ -n "$vk" ] && log "renderer: $vk (want gles:host; vulkan lavapipe/swiftshader = CPU raster)"
  # TCP, not ICMP: ping through the emulator NAT (slirp) is unreliable by design
  if "$ADB" -s "$serial" shell 'toybox nc -w 5 8.8.8.8 443 </dev/null >/dev/null 2>&1'; then
    log "network: TCP 8.8.8.8:443 OK"
  else
    warn "network: TCP 8.8.8.8:443 FAILED — check VPN/firewall on host (see 'make-avd doctor')"
  fi
  if "$ADB" -s "$serial" shell 'toybox nc -w 5 google.com 443 </dev/null >/dev/null 2>&1'; then
    log "network: DNS resolution OK"
  else
    warn "network: DNS FAILED — try relaunching with host DNS reachable or VPN off"
  fi
}

cmd_doctor() {
  echo "=== make-avd doctor ==="
  echo "--- HVF acceleration:"
  if "$EMU" -accel-check 2>/dev/null | grep -q Hypervisor; then
    echo "OK: Hypervisor.Framework available"
  else
    echo "FAIL: HVF not available — emulator will be unusably slow"
  fi
  echo "--- emulator version:"
  "$EMU" -version 2>/dev/null | head -1
  echo "--- running emulators (priority 4 = background-clamped, bad):"
  ps -o pid,pri,%cpu,command -p $(pgrep -f qemu-system 2>/dev/null | tr '\n' ',' | sed 's/,$//') 2>/dev/null | sed 1d | cut -c1-100 || echo "none"
  echo "--- orphaned crashpad handlers (dirty exits; safe to pkill):"
  local orphans
  orphans=$(pgrep -f 'sdk/emulator/crashpad_handler' | wc -l | tr -d ' ')
  if [ "$orphans" -gt 0 ]; then
    echo "$orphans found — clean with: pkill -f 'sdk/emulator/crashpad_handler'"
  else echo "none"; fi
  echo "--- host CPU top-5 (background load steals vCPU time -> guest starvation):"
  /usr/bin/top -l 2 -n 5 -o cpu -stats command,cpu 2>/dev/null | tail -5
  echo "--- host free memory:"
  vm_stat | awk '/free|inactive/ {gsub("\\.",""); printf "%s %.1f GB\n", $1" "$2, $NF*16384/1e9}'
  echo "--- AVDs:"
  cmd_list
  echo "--- adb devices:"
  "$ADB" devices | sed 1d | grep . || echo "none running"
  echo "--- SDK updates available (may take ~30s):"
  perl -e 'alarm 90; exec @ARGV' "$SDKMANAGER" --list 2>/dev/null \
    | sed -n '/Available Updates/,$p' | head -10 || echo "(sdkmanager check failed)"
}

cmd_list() {
  local ini
  for ini in "$AVD_HOME"/*.avd/config.ini; do
    [ -f "$ini" ] || continue
    local name ram gpu cores api
    name=$(basename "$(dirname "$ini")" .avd)
    ram=$(grep '^hw.ramSize=' "$ini" | cut -d= -f2)
    gpu=$(grep '^hw.gpu.mode=' "$ini" | cut -d= -f2)
    cores=$(grep '^hw.cpu.ncore=' "$ini" | cut -d= -f2)
    api=$(grep '^image.sysdir.1=' "$ini" | sed 's|.*android-\([0-9.]*\)/.*|\1|')
    printf '  %-14s api=%-5s ram=%-5s cores=%-2s gpu=%s\n' "$name" "${api:-?}" "${ram:-?}" "${cores:-?}" "${gpu:-?}"
  done
}

cmd_create() {
  local api=$1 name=${NAME:-api$1}
  require_tools
  local pkg dev
  pkg=$(pick_image "$api")
  dev=$(pick_device)
  local avd_dir="$AVD_HOME/${name}.avd"

  if [ -d "$avd_dir" ] && [ "$RECREATE" = yes ]; then
    log "recreating: deleting existing AVD '$name'"
    "$AVDMANAGER" delete avd -n "$name" >/dev/null 2>&1 || rm -rf "$avd_dir" "$AVD_HOME/${name}.ini"
  fi

  if [ ! -d "$avd_dir" ]; then
    log "creating AVD '$name' (API $api, $pkg, device $dev)"
    echo no | "$AVDMANAGER" create avd -n "$name" -k "$pkg" -d "$dev" -f >/dev/null
  else
    log "AVD '$name' already exists — enforcing tuned settings (idempotent)"
  fi

  tune_config "$avd_dir/config.ini"
  if [ "$SNAPSHOT" = no ] && [ -d "$avd_dir/snapshots" ]; then
    rm -rf "$avd_dir/snapshots"          # stale snapshots: 2 GB each + clock-skew source
  fi
  log "config enforced: ram=${RAM} heap=${HEAP} cores=${CORES} gpu=${GPU} disk=${DISK} snapshot=${SNAPSHOT}"

  [ "$LAUNCH" = yes ] && launch_avd "$name" || true
}

# ---- arg parsing ----
[ $# -ge 1 ] || usage 1
CMD=$1; shift
NAME=""
POSITIONAL=""
while [ $# -gt 0 ]; do
  case $1 in
    --name) NAME=$2; shift 2;;
    --ram) RAM=$2; shift 2;;
    --cores) CORES=$2; shift 2;;
    --heap) HEAP=$2; shift 2;;
    --disk) DISK=$2; shift 2;;
    --gpu) GPU=$2; shift 2;;
    --snapshot) SNAPSHOT=yes; shift;;
    --recreate) RECREATE=yes; shift;;
    --no-launch) LAUNCH=no; shift;;
    --no-wait) WAIT=no; shift;;
    -h|--help) usage;;
    *) POSITIONAL=$1; shift;;
  esac
done

case $CMD in
  doctor) cmd_doctor;;
  list) cmd_list;;
  delete)
    [ -n "$POSITIONAL" ] || die "usage: make-avd delete <name>"
    "$AVDMANAGER" delete avd -n "$POSITIONAL" && log "deleted $POSITIONAL";;
  launch)
    [ -n "$POSITIONAL" ] || die "usage: make-avd launch <name>"
    require_tools; launch_avd "$POSITIONAL";;
  -h|--help|help) usage;;
  *)
    [[ $CMD =~ ^[0-9]+(\.[0-9]+)?$ ]] || die "unknown command '$CMD' (try --help)"
    cmd_create "$CMD";;
esac
